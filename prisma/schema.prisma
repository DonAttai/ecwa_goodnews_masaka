generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String               @id @default(cuid())
  name                 String
  email                String               @unique
  password             String?
  role                 Role
  isActive             Boolean              @default(false)
  mustChangePassword   Boolean              @default(true)
  resetToken           String?              @unique
  resetTokenExpiry     DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  auditLogs            AuditLog[]
  PasswordSetupToken   PasswordSetupToken[]
  requisitions         Requisition[]        @relation("RequestedRequisitions")
  approvedRequisitions Requisition[]        @relation("ApprovedRequisitions")
}

model PasswordSetupToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Member {
  id                     String             @id @default(cuid())
  passportUrl            String?
  surname                String
  firstName              String
  otherNames             String?
  presentAddress         String
  phoneNumber            String
  email                  String?
  maritalStatus          MaritalStatus?
  gender                 Gender?
  spouseName             String?
  stateOfOrigin          String
  lga                    String
  tribe                  String
  previousPlaceOfWorship String?
  homeCell               String?
  zone                   String?
  acceptedChrist         String
  baptized               String
  baptismPlace           String?
  baptizedBy             String?
  communicant            String
  beenOnDiscipline       String
  disciplineReason       String?
  disciplineDate         DateTime?
  disciplineReliefDate   DateTime?
  previousChurchPosition String?
  suggestions            String?
  memberSignature        String?
  memberSignedDate       DateTime?
  pastorSignature        String?
  pastorSignedDate       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  children               Child[]
  fellowshipGroups       MemberFellowship[]
}

model Child {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  memberId  String
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model FellowshipGroup {
  id          String             @id @default(cuid())
  name        String             @unique
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  members     MemberFellowship[]
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      AuditAction
  entity      EntityType
  entityId    String?
  description String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entity, entityId])
}

model MemberFellowship {
  memberId     String
  fellowshipId String
  addedAt      DateTime        @default(now())
  role         String?
  fellowship   FellowshipGroup @relation(fields: [fellowshipId], references: [id], onDelete: Cascade)
  member       Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([memberId, fellowshipId])
  @@map("member_fellowships")
}

model Requisition {
  id               String               @id @default(cuid())
  title            String
  description      String?
  category         String
  amount           Float?
  currency         String               @default("NGN")
  priority         RequisitionPriority  @default(MEDIUM)
  status           RequisitionStatus    @default(PENDING)
  dueDate          DateTime?
  requestedById    String
  requestedBy      User                 @relation("RequestedRequisitions", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedById     String?
  approvedBy       User?                @relation("ApprovedRequisitions", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([requestedById, status])
}

model Settings {
  id             Int      @id @default(1)
  churchName     String
  address        String?
  phone          String?
  email          String?
  website        String?
  logoUrl        String?
  welcomeMessage String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("settings")
}

enum Role {
  ADMIN
  WORKER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
}

enum Gender {
  MALE
  FEMALE
}

enum AuditAction {
  // Authentication
  LOGIN
  LOGOUT

  // Users
  CREATE_USER
  UPDATE_USER
  DELETE_USER

  // Members
  CREATE_MEMBER
  UPDATE_MEMBER
  DELETE_MEMBER
}

enum EntityType {
  MEMBER
  USER
}

enum RequisitionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum RequisitionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
